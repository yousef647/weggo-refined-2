# MongoDB (local)
MONGODB_URI=mongodb://127.0.0.1:27017/weggo

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Site URL for NextAuth callbacks (local)
AUTH_URL=http://localhost:3000

# Optional: send real reset emails (e.g. Resend). If unset, dev may log reset links when LOG_RESET_LINK=true
EMAIL_FROM=
RESEND_API_KEY=

# When true (and no email configured), password reset link is printed to server console (local dev only)
LOG_RESET_LINK=true

# seed:admin — only for local seed script (creates admin if missing)
SEED_ADMIN_EMAIL=admin@weggo.local
SEED_ADMIN_PASSWORD=ChangeMe123!
